# Server environment variables

# API port
PORT=5000

# Node environment
NODE_ENV=development

# Allowed client origin (comma-separated list supported)
CLIENT_ORIGIN=http://localhost:5173

# Request logging override: true|false (defaults to true in development)
REQUEST_LOGGING=true

# Max JSON payload size accepted by Express (e.g., 1mb, 2mb)
JSON_BODY_LIMIT=1mb

# Graceful shutdown timeout before forced exit (milliseconds)
SHUTDOWN_TIMEOUT_MS=10000
