# Server environment variables

# API port
PORT=5000

# Node environment
NODE_ENV=development

# Allowed client origin (comma-separated list supported)
CLIENT_ORIGIN=http://localhost:5173

# Request logging override: true|false (defaults to true in development)
REQUEST_LOGGING=true

# Max JSON payload size accepted by Express (e.g., 1mb, 2mb)
JSON_BODY_LIMIT=1mb

# Graceful shutdown timeout before forced exit (milliseconds)
SHUTDOWN_TIMEOUT_MS=10000

# API rate limiting (window in ms + max requests per IP per window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# Reverse proxy + performance toggles
TRUST_PROXY=false
COMPRESSION_ENABLED=true
